# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Database SQLite
prisma/*.db
prisma/*.db-journal
prisma/*.db.bak

# Upload files
/public/uploads/*
!/public/uploads/.gitkeep

# Media files (PDF, JPG, MP3, MP4, ecc.)
# /public/media/**/*
# !/public/media/**/.gitkeep

# Script temporanei
fix-*.mjs

# File temporanei
*.tmp
